                    <mxGeometry x="30" y="250" width="1420" height="330" as="geometry"/>
                </mxCell>
                <mxCell id="31" value="模块 1：低比特量化（第3章）&#xa;1-bit Adam：动量累积 → 自适应归一化 → 随机量化 → 误差补偿&#xa;量化策略：FP32梯度 → 伯努利采样 → 二值{0,1}&#xa;压缩比：32×(1-bit) | 16×(2-bit) | 4×(8-bit)&#xa;作用：降低跨域通信体积，缓解接入/广域带宽瓶颈" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor:#FA8C16;spacing=6;fontSize=10;" parent="30" vertex="1">
                    <mxGeometry x="20" y="70" width="420" height="220" as="geometry"/>
                </mxCell>
                <mxCell id="32" value="模块 2：分层集合通信流水化（第4章）&#xa;异构网络：域内快(RDMA/NVLink) vs 域间慢(WAN)&#xa;层次化All-Reduce：本地归约 → 跨域同步 → 本地广播&#xa;流水线分块：张量8～16块，降低启动开销占比&#xa;双流并行：Intra-stream(域内) | Inter-stream(域间)&#xa;作用：提升慢链路利用率，隐藏高RTT启动开销" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor:#FA8C16;spacing=6;fontSize=10;" parent="30" vertex="1">
                    <mxGeometry x="480" y="70" width="420" height="220" as="geometry"/>
                </mxCell>
                <mxCell id="33" value="模块 3：计算-通信掩盖（第5章）&#xa;问题：WAN同步尾部无法被剩余计算掩盖&#xa;解决方案POLAR-SGD：&#xa;  • 前缀触发：micro-batch前缀启动All-Reduce&#xa;  • 异步执行：不阻塞后续反向计算&#xa;  • 预测修正：维持梯度一致性与收敛稳定性&#xa;DP+PP混合：跨域DP + 域内PP强化掩盖&#xa;作用：削减同步尾部，提升计算效率与网络容错" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor:#FA8C16;spacing=6;fontSize=10;" parent="30" vertex="1">
                    <mxGeometry x="940" y="70" width="420" height="220" as="geometry"/>
                </mxCell>

                <mxCell id="100" value="约束驱动" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#595959;endArrow=block;" parent="1" source="10" target="20" edge="1">
